// schema.prisma — SafeCircle single source of truth for DB
// Postgres 16+ required for partition support.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum SessionType {
  CHECKIN
  SAFERIDE
  WALKALONE
  SOS
}

enum SessionStatus {
  IDLE
  SETTING_UP
  ACTIVE
  COMPLETED
  ESCALATED
  CANCELLED
}

enum AlertType {
  DELAYED_ARRIVAL
  ROUTE_DEVIATION
  UNEXPLAINED_STOP
  NON_RESPONSE
  SOS_TRIGGERED
  SOS_ESCALATED_SMS
  SOS_ESCALATED_CALL
  SESSION_CANCELLED
  SESSION_COMPLETED
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertStatus {
  SENT
  DELIVERED
  ACKNOWLEDGED
  FAILED
}

enum AlertChannel {
  PUSH
  SMS
  CALL
  IN_APP
}

enum Relationship {
  FAMILY
  FRIEND
  COLLEAGUE
  PARTNER
  OTHER
}

enum ContactStatus {
  PENDING
  ACTIVE
  REVOKED
}

// ─── Users ────────────────────────────────────────────────────────────────────

model User {
  id              String   @id @default(uuid())
  phone           String   @unique
  name            String
  pushTokens      String[] @default([]) // Expo push tokens for this user's devices
  privacySettings Json     @default("{\"locationRetentionDays\":30,\"shareLocationWithContacts\":true,\"reduceLocationPrecision\":false}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ownedContacts    TrustedContact[] @relation("ContactOwner")
  contactEntries   TrustedContact[] @relation("ContactUser")
  sessions         SafetySession[]
  auditLogs        AuditLog[]

  @@map("users")
}

// ─── Trusted Contacts ─────────────────────────────────────────────────────────

model TrustedContact {
  id              String        @id @default(uuid())
  ownerId         String
  contactUserId   String?       // null until invite accepted by a SafeCircle user
  phone           String
  name            String
  relationship    Relationship
  alertChannels   AlertChannel[]
  isVerified      Boolean       @default(false)
  status          ContactStatus @default(PENDING)
  inviteToken     String?       @unique
  inviteExpiresAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  owner       User  @relation("ContactOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  contactUser User? @relation("ContactUser", fields: [contactUserId], references: [id], onDelete: SetNull)

  @@unique([ownerId, phone])
  @@index([ownerId])
  @@index([inviteToken])
  @@map("trusted_contacts")
}

// ─── Safety Sessions ──────────────────────────────────────────────────────────

model SafetySession {
  id        String        @id @default(uuid())
  userId    String
  type      SessionType
  status    SessionStatus @default(ACTIVE)
  subStatus String        @default("TRACKING") // string to accommodate all type-specific sub-states
  policy    Json          // discriminated union SessionPolicy
  shareWith String[]      // array of trusted_contact UUIDs
  startedAt DateTime      @default(now())
  endedAt   DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user                   User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkInDetails         CheckInSessionDetails?
  safeRideDetails        SafeRideSessionDetails?
  walkAloneDetails       WalkAloneSessionDetails?
  alerts                 AlertEvent[]
  locationPings          LocationPing[]

  @@index([userId])
  @@index([status])
  @@index([type, status])
  @@map("safety_sessions")
}

model CheckInSessionDetails {
  sessionId         String    @id
  destination       String
  etaAt             DateTime
  gracePeriodMinutes Int      @default(15)
  arrivedAt         DateTime?
  overdueAt         DateTime?

  session SafetySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("checkin_session_details")
}

model SafeRideSessionDetails {
  sessionId               String  @id
  originLat               Float
  originLng               Float
  destinationLat          Float
  destinationLng          Float
  routePolyline           String  @db.Text
  deviationThresholdMeters Int    @default(200)
  stopThresholdSeconds    Int     @default(120)
  firstDeviationAt        DateTime?
  firstStopAt             DateTime?

  session SafetySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("saferide_session_details")
}

model WalkAloneSessionDetails {
  sessionId            String   @id
  promptIntervalSeconds Int     @default(300)
  lastPromptAt         DateTime?
  lastResponseAt       DateTime?

  session SafetySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("walkalone_session_details")
}

// ─── Location Pings ───────────────────────────────────────────────────────────
// NOTE: This table is partitioned by month (RANGE on recorded_at) via raw SQL migration.
// Prisma models it as unpartitioned; partitioning is applied via a separate migration file.

model LocationPing {
  id         String    @id @default(uuid())
  sessionId  String
  userId     String
  lat        Float
  lng        Float
  accuracy   Float
  altitude   Float?
  speed      Float?
  heading    Float?
  geohash6   String    // reduced-precision long-term storage
  recordedAt DateTime

  session SafetySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, recordedAt])
  @@index([userId, recordedAt])
  @@index([geohash6])
  @@map("location_pings")
}

// ─── Alert Events (immutable append-only) ─────────────────────────────────────

model AlertEvent {
  id               String        @id @default(uuid())
  sessionId        String
  userId           String
  type             AlertType
  severity         AlertSeverity
  message          String
  metadata         Json          @default("{}")
  notifiedContacts String[]      // trusted_contact UUIDs
  channels         AlertChannel[]
  status           AlertStatus   @default(SENT)
  acknowledgedAt   DateTime?
  acknowledgedBy   String?       // contact UUID who acked
  createdAt        DateTime      @default(now())

  // No updatedAt — immutable. Only acknowledgedAt is set once via a controlled method.
  session SafetySession @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([userId, createdAt])
  @@index([status])
  @@map("alert_events")
}

// ─── Audit Log (append-only) ──────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String   // e.g. "SESSION_STARTED", "CONTACT_ADDED", "OTP_VERIFIED"
  resource  String?  // e.g. "SafetySession:uuid"
  metadata  Json     @default("{}")
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_log")
}

// ─── Refresh Tokens ───────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique // bcrypt hash of the refresh token
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}
