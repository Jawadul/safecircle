{
  "extends": "@safecircle/config/tsconfig/node.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "composite": false,
    "paths": {
      "@safecircle/shared-types": ["../../packages/shared-types/dist/index"],
      "@safecircle/shared-utils": ["../../packages/shared-utils/dist/index"]
    }
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "../../packages",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}
